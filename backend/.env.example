NODE_ENV=development
PORT=5000
# Update this connection string if your MongoDB has authentication enabled.
# For example, with docker-compose: mongodb://admin:admin123@mongo:27017/iAttend?authSource=admin
MONGO_URI=mongodb://mongo:27017/iAttend

# Ensure you use a strong, generated string for JWT_SECRET in production
JWT_SECRET=your_jwt_secret_placeholder
